generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Moto {
  id               Int      @id @default(autoincrement())
  marca            String
  modelo           String
  potencia         String?
  precoVarejo      Float?
  precoAtacado     Float?
  qtdMinimaAtacado Int?
  autonomia        String?
  peso             String?
  cargaMaxima      String?
  tempoRecarga     String?
  voltagem         String?
  observacoes      String?
  fotoUrl1         String?
  fotoUrl2         String?
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  @@map("motos")
}